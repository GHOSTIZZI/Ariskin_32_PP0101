<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>

<AnchorPane prefHeight="600.0" prefWidth="950.0" style="-fx-background-color: #E3E3E3;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.praktika.CartController">
    <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">

        <!-- Верхняя панель навигации -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Button text="←"
                    onAction="#handleBack"
                    AnchorPane.leftAnchor="25.0"
                    AnchorPane.topAnchor="25.0"
                    style="
                    -fx-font-size: 25px;
                    -fx-padding: 9 16 9 16;
                    -fx-text-fill: black;
                    -fx-border-width: 1px;
                    -fx-background-radius: 50%;
                    -fx-border-radius: 50%;
                    -fx-cursor: hand;
                    -fx-background-color: #ffffff;
                    -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);"/>
            <Label text="Корзина" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: black;"/>

            <Region HBox.hgrow="ALWAYS" />

        </HBox>

        <!-- Основной контейнер (Разделение на список и панель оформления) -->
        <HBox spacing="20.0" VBox.vgrow="ALWAYS">

            <!-- Левая часть: Сменяемый контент (Список товаров ИЛИ Форма оформления) -->
            <StackPane fx:id="mainContentStack" HBox.hgrow="ALWAYS">

                <!-- 1. Прокручиваемый список карточек товаров -->
                <ScrollPane fx:id="cartScrollPane" fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="cartItemsContainer" spacing="12.0">
                        <padding>
                            <Insets right="10.0"/>
                        </padding>
                    </VBox>
                </ScrollPane>

                <!-- 2. Имитационное окно оформления заказа (по умолчанию скрыто) -->
                <VBox fx:id="checkoutFormPane" spacing="20.0" style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-border-color: #ffffff; -fx-border-radius: 116;" visible="false">
                    <padding>
                        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
                    </padding>
                    <Label text="Оформление заказа (Имитация)" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>

                    <GridPane vgap="15" hgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="120" prefWidth="120"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>

                        <Label text="Email:" style="-fx-text-fill: #b3b3b3;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="emailField" promptText="example@mail.ru" style="-fx-background-color: #E3E3E3; -fx-text-fill: black;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Адрес доставки:" style="-fx-text-fill: #b3b3b3;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <TextField fx:id="addressField" promptText="г. Энгельс, ул. Студенческая, д. 1" style="-fx-background-color: #E3E3E3; -fx-text-fill: black;" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Способ оплаты:" style="-fx-text-fill: #b3b3b3;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <ComboBox fx:id="paymentMethodComboBox" promptText="Выберите способ" prefWidth="200" style="-fx-background-color:  #E3E3E3; -fx-text-fill: black;" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    </GridPane>

                    <Region VBox.vgrow="ALWAYS"/>
                    <HBox spacing="15" alignment="CENTER_RIGHT">
                        <Button onAction="#cancelCheckout" text="Отмена" style="-fx-background-color: #333333; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8;"/>
                        <Button onAction="#confirmPurchase" text="Подтвердить покупку" style="-fx-background-color: #ff9800; -fx-text-fill: black; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8;"/>
                    </HBox>
                </VBox>
            </StackPane>

            <!-- Правая часть: Панель условий и цены (как на скриншоте) -->
            <VBox prefWidth="280.0" spacing="20.0" style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-border-color: #ffffff; -fx-border-radius: 16;" maxHeight="300">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                </padding>

                <Label text="Условия заказа" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: black;"/>
                <Separator style="-fx-background-color: #333333;"/>

                <VBox spacing="10">
                    <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ffffff;">
                        <Label fx:id="itemsCountLabel" text="0 товаров" style="-fx-text-fill: black; -fx-font-size: 14px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="totalLabel" text="0.00 ₽" style="-fx-text-fill: black; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                    </HBox>
                    <Label text="Доставка: Бесплатно" style="-fx-text-fill: #4caf50; -fx-font-size: 12px;"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Главная кнопка перехода к оформлению -->
                <Button fx:id="checkoutActionButton" onAction="#handleCheckout" prefWidth="240.0" text="Перейти к оформлению"
                        style="-fx-background-color: #ff9800; -fx-text-fill: black; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </VBox>
        </HBox>
    </VBox>
</AnchorPane>